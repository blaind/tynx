+
+    #[test]
+    fn i64_min_constant_has_typed_subtraction_and_vector_splat() {
+        let scalar = Variable::Constant(ConstantValue::Int(i64::MIN), Item::Scalar(Elem::I64));
+        let vector = Variable::Constant(ConstantValue::Int(i64::MIN), Item::Vector(Elem::I64, 2));
+
+        assert_eq!(
+            scalar.to_string(),
+            "(i64(-9223372036854775807) - i64(1))"
+        );
+        assert_eq!(
+            vector.to_string(),
+            "vec2<i64>((i64(-9223372036854775807) - i64(1)))"
+        );
+    }
