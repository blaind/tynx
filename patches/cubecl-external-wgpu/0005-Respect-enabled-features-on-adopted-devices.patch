@@ -355,7 +355,8 @@ pub(crate) fn create_server<C: WgpuCompiler>(
 
     let mut compilation_options = Default::default();
 
-    let features = setup.adapter.features();
+    // An adopted device may enable only a subset of its adapter's capabilities.
+    let features = setup.device.features();
 
     let time_measurement = if features.contains(wgpu::Features::TIMESTAMP_QUERY) {
         TimingMethod::Device
@@ -389,6 +390,7 @@ pub(crate) fn create_server<C: WgpuCompiler>(
 
     backend::register_features(
         &setup.adapter,
+        features,
         &mut device_props,
         &mut compilation_options,
         &options.memory_config,
