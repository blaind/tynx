+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    fn noop_device() -> wgpu::Device {
+        let instance = wgpu::Instance::new(wgpu::InstanceDescriptor {
+            backends: wgpu::Backends::NOOP,
+            backend_options: wgpu::BackendOptions {
+                noop: wgpu::NoopBackendOptions {
+                    enable: true,
+                    ..Default::default()
+                },
+                ..Default::default()
+            },
+            ..wgpu::InstanceDescriptor::new_without_display_handle()
+        });
+        let adapter = cubecl_common::future::block_on(
+            instance.request_adapter(&wgpu::RequestAdapterOptions::default()),
+        )
+        .unwrap();
+        let (device, _queue) = cubecl_common::future::block_on(
+            adapter.request_device(&wgpu::DeviceDescriptor::default()),
+        )
+        .unwrap();
+        device
+    }
+
+    #[test]
+    fn external_registration_retains_the_original_buffer() {
+        let device = noop_device();
+        let buffer = device.create_buffer(&wgpu::BufferDescriptor {
+            label: Some("cubecl external registration test"),
+            size: 512,
+            usage: BufferUsages::STORAGE | BufferUsages::COPY_DST,
+            mapped_at_creation: false,
+        });
+        let mut storage = WgpuStorage::new(
+            256,
+            device,
+            BufferUsages::STORAGE | BufferUsages::COPY_DST,
+            false,
+        );
+
+        let handle = storage
+            .register_external(WgpuResource::from_external_buffer(buffer.clone(), 256, 128))
+            .unwrap();
+        let resource = storage.get(&handle);
+
+        assert_eq!(resource.buffer, buffer);
+        assert_eq!(resource.offset, 256);
+        assert_eq!(resource.size, 128);
+    }
+
