+    fn register_external(&mut self, resource: Self::Resource) -> Result<StorageHandle, IoError> {
+        if resource.size == 0 {
+            return Err(IoError::InvalidResource {
+                reason: "external wgpu resources must have a positive logical size".into(),
+                backtrace: cubecl_common::backtrace::BackTrace::capture(),
