+++ b/crates/cubecl-runtime/src/memory_management/memory_pool/external_pool.rs
@@ -0,0 +1,164 @@
+use alloc::vec::Vec;
+use cubecl_common::backtrace::BackTrace;
+
+use super::{ManagedMemoryBinding, ManagedMemoryHandle, Slice};
+use crate::{
+    memory_management::{MemoryLocation, MemoryUsage},
+    server::IoError,
+    storage::{ComputeStorage, StorageHandle},
+};
+
+pub(crate) const EXTERNAL_POOL_INDEX: u8 = u8::MAX;
+
+/// Tracks externally allocated storage without making it available for ordinary reservations.
+pub(crate) struct ExternalMemoryPool {
+    slices: Vec<Slice>,
+}
+
+impl ExternalMemoryPool {
+    pub(crate) fn new() -> Self {
+        Self { slices: Vec::new() }
+    }
+
+    pub(crate) fn register(
+        &mut self,
+        storage: StorageHandle,
+    ) -> Result<ManagedMemoryHandle, IoError> {
+        let slice_index =
+            u32::try_from(self.slices.len()).map_err(|_| IoError::InvalidResource {
+                reason: "external memory registry exhausted".into(),
+                backtrace: BackTrace::capture(),
+            })?;
+        let slice = Slice::new(storage, 0);
+        slice.descriptor().update_location(MemoryLocation::new(
+            EXTERNAL_POOL_INDEX,
+            0,
+            slice_index,
+        ));
+        let handle = slice.handle.clone();
+        self.slices.push(slice);
+        Ok(handle)
+    }
+
+    pub(crate) fn find(&self, binding: &ManagedMemoryBinding) -> Result<&Slice, IoError> {
+        let slice_index = binding.descriptor().slice();
+        let slice = self
+            .slices
+            .get(slice_index)
+            .ok_or_else(|| IoError::NotFound {
+                backtrace: BackTrace::capture(),
+                reason: alloc::format!("External memory slice {slice_index} doesn't exist").into(),
+            })?;
+
+        if slice.handle.descriptor() != binding.descriptor() {
+            return Err(IoError::NotFound {
+                backtrace: BackTrace::capture(),
+                reason: "external memory binding no longer identifies that slice".into(),
+            });
+        }
+
+        Ok(slice)
+    }
+
+    pub(crate) fn cleanup<Storage: ComputeStorage>(&mut self, storage: &mut Storage) {
+        let mut retained = Vec::with_capacity(self.slices.len());
+        for slice in self.slices.drain(..) {
+            if slice.is_free() {
+                storage.dealloc(slice.storage.id);
+            } else {
+                let slice_index = retained.len() as u32;
+                slice.descriptor().update_slice(slice_index);
+                retained.push(slice);
+            }
+        }
+        self.slices = retained;
+        storage.flush();
+    }
+
+    pub(crate) fn get_memory_usage(&self) -> MemoryUsage {
+        let used_slices: Vec<_> = self
+            .slices
+            .iter()
+            .filter(|slice| !slice.is_free())
+            .collect();
+
+        MemoryUsage {
+            number_allocs: used_slices.len() as u64,
+            bytes_in_use: used_slices.iter().map(|slice| slice.storage.size()).sum(),
+            bytes_padding: 0,
+            bytes_reserved: self.slices.iter().map(|slice| slice.storage.size()).sum(),
+        }
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use crate::storage::{StorageId, StorageUtilization};
+    use alloc::vec;
+
+    #[derive(Debug, Default)]
+    struct TestStorage {
+        deallocated: Vec<StorageId>,
+    }
+
+    impl ComputeStorage for TestStorage {
+        type Resource = ();
+
+        fn alignment(&self) -> usize {
+            1
+        }
+
+        fn get(&mut self, _handle: &StorageHandle) -> Self::Resource {}
+
+        fn alloc(&mut self, _size: u64) -> Result<StorageHandle, IoError> {
+            unreachable!("external-pool tests do not allocate storage")
+        }
+
+        fn dealloc(&mut self, id: StorageId) {
+            self.deallocated.push(id);
+        }
+
+        fn flush(&mut self) {}
+    }
+
+    fn storage_handle(size: u64) -> StorageHandle {
+        StorageHandle::new(StorageId::new(), StorageUtilization { offset: 0, size })
+    }
+
+    #[test]
+    fn external_slices_are_never_reused_as_reservations() {
+        let mut pool = ExternalMemoryPool::new();
+        let first = pool.register(storage_handle(64)).unwrap();
+        let first_id = pool.find(&first.clone().binding()).unwrap().storage.id;
+        drop(first);
+
+        let second = pool.register(storage_handle(64)).unwrap();
+        let second_id = pool.find(&second.clone().binding()).unwrap().storage.id;
+
+        assert_ne!(first_id, second_id);
+        assert_eq!(pool.slices.len(), 2);
+    }
+
+    #[test]
+    fn cleanup_drops_free_storage_and_updates_retained_locations() {
+        let mut pool = ExternalMemoryPool::new();
+        let released = pool.register(storage_handle(64)).unwrap();
+        let released_id = pool.find(&released.clone().binding()).unwrap().storage.id;
+        let retained = pool.register(storage_handle(128)).unwrap();
+        drop(released);
+
+        let mut storage = TestStorage::default();
+        pool.cleanup(&mut storage);
+
+        assert_eq!(storage.deallocated, vec![released_id]);
+        assert_eq!(
+            pool.find(&retained.clone().binding())
+                .unwrap()
+                .storage
+                .size(),
+            128
+        );
+        assert_eq!(retained.descriptor().slice(), 0);
+    }
+}
