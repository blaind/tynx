+
+        assert!(matches!(
+            storage.register_external(WgpuResource::from_external_buffer(missing_usage, 0, 128)),
+            Err(IoError::InvalidResource { .. })
+        ));
+        assert!(matches!(
+            storage.register_external(WgpuResource::from_external_buffer(
+                storage_buffer.clone(),
+                4,
+                128
+            )),
+            Err(IoError::InvalidResource { .. })
+        ));
+        assert!(matches!(
+            storage.register_external(WgpuResource::from_external_buffer(storage_buffer, 256, 512)),
+            Err(IoError::InvalidResource { .. })
+        ));
+    }
+}
