+    retention: Option<Arc<dyn WgpuResourceRetention>>,
 }

 /// The memory that can be allocated for wgpu.
-#[derive(new, Debug)]
 pub struct WgpuMemory {
     /// The wgpu buffer.
     pub buffer: wgpu::Buffer,
     /// The buffer device address, if supported
     pub address: Option<NonZeroU64>,
+    retention: Option<Arc<dyn WgpuResourceRetention>>,
+}
+
+/// Type-erased owner retained alongside an externally registered wgpu buffer.
+///
+/// Engine integrations can use this to keep a logical slot lease alive even though cloning the
+/// underlying [`wgpu::Buffer`] would otherwise allow that slot to be recycled.
+pub trait WgpuResourceRetention: Send + Sync {}
+
+impl<T> WgpuResourceRetention for T where T: Send + Sync {}
+
+impl core::fmt::Debug for WgpuResource {
+    fn fmt(&self, formatter: &mut core::fmt::Formatter<'_>) -> core::fmt::Result {
+        formatter
+            .debug_struct("WgpuResource")
+            .field("buffer", &self.buffer)
+            .field("address", &self.address)
+            .field("offset", &self.offset)
+            .field("size", &self.size)
+            .field("retained", &self.retention.is_some())
+            .finish()
+    }
+}
+
+impl core::fmt::Debug for WgpuMemory {
+    fn fmt(&self, formatter: &mut core::fmt::Formatter<'_>) -> core::fmt::Result {
+        formatter
+            .debug_struct("WgpuMemory")
+            .field("buffer", &self.buffer)
+            .field("address", &self.address)
+            .field("retained", &self.retention.is_some())
+            .finish()
+    }
+}
+
+impl WgpuMemory {
+    fn new(buffer: wgpu::Buffer, address: Option<NonZeroU64>) -> Self {
+        Self {
+            buffer,
+            address,
+            retention: None,
+        }
+    }
 }

 impl WgpuResource {
+    /// Creates a resource view without an external lifetime sidecar.
+    pub fn new(buffer: wgpu::Buffer, address: Option<NonZeroU64>, offset: u64, size: u64) -> Self {
+        Self {
+            buffer,
+            address,
+            offset,
+            size,
+            retention: None,
+        }
+    }
+
     /// Creates a view over an externally allocated wgpu buffer.
     ///
     /// The buffer must belong to the same device as the `CubeCL` client that registers it.
@@ -59,6 +112,33 @@ impl WgpuResource {
         Self::new(buffer, None, offset, size)
     }

+    /// Creates an external buffer view that retains its logical owner.
+    ///
+    /// The retention value remains alive while a managed handle or queued wgpu binding can access
+    /// the buffer.
+    pub fn from_external_buffer_with_retention<T>(
+        buffer: wgpu::Buffer,
+        offset: u64,
+        size: u64,
+        retention: Arc<T>,
+    ) -> Self
+    where
+        T: Send + Sync + 'static,
+    {
+        Self {
+            buffer,
+            address: None,
+            offset,
+            size,
+            retention: Some(retention),
+        }
+    }
+
+    fn with_retention(mut self, retention: Option<Arc<dyn WgpuResourceRetention>>) -> Self {
+        self.retention = retention;
+        self
+    }
+
     /// Return the binding view of the buffer.
     pub fn as_wgpu_bind_resource(&self) -> wgpu::BindingResource<'_> {
         // wgpu enforces 4-byte alignment for buffer binding sizes per the WebGPU spec.
@@ -115,6 +195,7 @@ impl ComputeStorage for WgpuStorage {
             handle.offset(),
             handle.size(),
         )
+        .with_retention(memory.retention.clone())
     }

     #[cfg_attr(
@@ -206,8 +287,14 @@ impl ComputeStorage for WgpuStorage {
             offset: resource.offset,
             size: resource.size,
         };
-        self.memory
-            .insert(id, WgpuMemory::new(resource.buffer, resource.address));
+        self.memory.insert(
+            id,
+            WgpuMemory {
+                buffer: resource.buffer,
+                address: resource.address,
+                retention: resource.retention,
+            },
+        );
         Ok(StorageHandle::new(id, utilization))
     }

@@ -330,4 +417,33 @@ mod tests {
             Err(IoError::InvalidResource { .. })
         ));
     }
+
+    #[test]
+    fn external_retention_outlives_storage_while_a_binding_resource_exists() {
+        #[derive(Debug)]
+        struct Retention;
+
+        let device = noop_device();
+        let buffer = device.create_buffer(&wgpu::BufferDescriptor {
+            label: None,
+            size: 256,
+            usage: BufferUsages::STORAGE,
+            mapped_at_creation: false,
+        });
+        let retention = Arc::new(Retention);
+        let retained = Arc::downgrade(&retention);
+        let mut storage = WgpuStorage::new(256, device, BufferUsages::STORAGE, false);
+        let handle = storage
+            .register_external(WgpuResource::from_external_buffer_with_retention(
+                buffer, 0, 256, retention,
+            ))
+            .unwrap();
+        let queued_resource = storage.get(&handle);
+
+        storage.dealloc(handle.id);
+        assert!(retained.upgrade().is_some());
+
+        drop(queued_resource);
+        assert!(retained.upgrade().is_none());
+    }
 }
