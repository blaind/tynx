def chunk(input: Tensor, chunks: int, dim: int = 0) -> tuple[Tensor, ...]: ...
def sort(
    input: Tensor, dim: int = -1, descending: bool = False, stable: bool = False
) -> tuple[Tensor, Tensor]: ...
def argsort(
    input: Tensor, dim: int = -1, descending: bool = False, stable: bool = False
