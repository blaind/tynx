def _adaptive_avg_pool2d(input: Tensor, output_size: tuple[int, int]) -> Tensor: ...
def _embedding(input: Tensor, weight: Tensor, padding_idx: int | None) -> Tensor: ...
def get_default_device() -> Device: ...
def synchronize(device: Device | None = None) -> None: ...
def cat(tensors: Sequence[Tensor], dim: int = 0) -> Tensor: ...
def stack(tensors: Sequence[Tensor], dim: int = 0) -> Tensor: ...
def split(
    input: Tensor, split_size_or_sections: int | Sequence[int], dim: int = 0
