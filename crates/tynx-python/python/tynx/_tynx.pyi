from collections.abc import Iterable
from os import PathLike
from typing import Literal, overload

from typing_extensions import TypeAlias

__version__: str

TensorScalar: TypeAlias = float | int | bool
TensorData: TypeAlias = TensorScalar | list["TensorData"] | tuple["TensorData", ...]
TensorDType: TypeAlias = Literal["float32", "int64", "bool"]
ReductionDim: TypeAlias = int | tuple[int, ...]
Scalar: TypeAlias = int | float
Shape: TypeAlias = tuple[int, ...] | list[int]

class _NoGrad:
    def __enter__(self) -> None: ...
    def __exit__(self, exception_type: object, exception: object, traceback: object) -> bool: ...

def no_grad() -> _NoGrad: ...
def is_grad_enabled() -> bool: ...
def where(
    condition: Tensor, input: Tensor | TensorScalar, other: Tensor | TensorScalar
) -> Tensor: ...
def maximum(input: Tensor, other: Tensor | TensorScalar) -> Tensor: ...
def minimum(input: Tensor, other: Tensor | TensorScalar) -> Tensor: ...
def clip_grad_norm_(
    parameters: Iterable[Parameter], max_norm: float, norm_type: float = 2.0
) -> Tensor: ...
def clip_grad_value_(parameters: Iterable[Parameter], clip_value: float) -> None: ...

class Tensor:
    def __init__(
        self,
        data: TensorData,
        *,
        dtype: TensorDType = "float32",
        requires_grad: bool = False,
    ) -> None: ...
    @property
    def shape(self) -> tuple[int, ...]: ...
    @property
    def ndim(self) -> int: ...
    @property
    def numel(self) -> int: ...
    @property
    def dtype(self) -> str: ...
    @property
    def requires_grad(self) -> bool: ...
    @property
    def is_leaf(self) -> bool: ...
    @property
    def grad(self) -> Tensor | None: ...
    def tolist(self) -> list[object]: ...
    def item(self) -> float | int | bool: ...
    def detach(self) -> Tensor: ...
    def zero_grad(self) -> None: ...
    def backward(self, gradient: Tensor | None = None) -> None: ...
    def sum(self, dim: ReductionDim | None = None, keepdim: bool = False) -> Tensor: ...
    def mean(self, dim: ReductionDim | None = None, keepdim: bool = False) -> Tensor: ...
    def max(self, dim: ReductionDim | None = None, keepdim: bool = False) -> Tensor: ...
    def min(self, dim: ReductionDim | None = None, keepdim: bool = False) -> Tensor: ...
    def maximum(self, other: Tensor | TensorScalar) -> Tensor: ...
    def minimum(self, other: Tensor | TensorScalar) -> Tensor: ...
    def relu(self) -> Tensor: ...
    def sigmoid(self) -> Tensor: ...
    def tanh(self) -> Tensor: ...
    def exp(self) -> Tensor: ...
    def log(self) -> Tensor: ...
    def sqrt(self) -> Tensor: ...
    def gelu(self) -> Tensor: ...
    def softmax(self, dim: int) -> Tensor: ...
    def log_softmax(self, dim: int) -> Tensor: ...
    def clamp(self, min: float | None = None, max: float | None = None) -> Tensor: ...
    def clip(self, min: float | None = None, max: float | None = None) -> Tensor: ...
    @overload
    def reshape(self, shape: Shape) -> Tensor: ...
    @overload
    def reshape(self, *shape: int) -> Tensor: ...
    def flatten(self, start_dim: int = 0, end_dim: int = -1) -> Tensor: ...
    def transpose(self, dim0: int, dim1: int) -> Tensor: ...
    @overload
    def permute(self, dims: Shape) -> Tensor: ...
    @overload
    def permute(self, *dims: int) -> Tensor: ...
    def squeeze(self, dim: int | None = None) -> Tensor: ...
    def unsqueeze(self, dim: int) -> Tensor: ...
    def where(self, condition: Tensor, other: Tensor | TensorScalar) -> Tensor: ...
    def gather(self, dim: int, index: Tensor) -> Tensor: ...
    def __add__(self, other: Tensor | Scalar) -> Tensor: ...
    def __radd__(self, other: Scalar) -> Tensor: ...
    def __sub__(self, other: Tensor | Scalar) -> Tensor: ...
    def __rsub__(self, other: Scalar) -> Tensor: ...
    def __mul__(self, other: Tensor | Scalar) -> Tensor: ...
    def __rmul__(self, other: Scalar) -> Tensor: ...
    def __truediv__(self, other: Tensor | Scalar) -> Tensor: ...
    def __rtruediv__(self, other: Scalar) -> Tensor: ...
    def __matmul__(self, other: Tensor) -> Tensor: ...
    def __neg__(self) -> Tensor: ...
    def __eq__(self, other: Tensor | TensorScalar) -> Tensor: ...  # type: ignore[override]
    def __ne__(self, other: Tensor | TensorScalar) -> Tensor: ...  # type: ignore[override]
    def __lt__(self, other: Tensor | TensorScalar) -> Tensor: ...
    def __le__(self, other: Tensor | TensorScalar) -> Tensor: ...
    def __gt__(self, other: Tensor | TensorScalar) -> Tensor: ...
    def __ge__(self, other: Tensor | TensorScalar) -> Tensor: ...
    def __and__(self, other: Tensor) -> Tensor: ...
    def __or__(self, other: Tensor) -> Tensor: ...
    def __xor__(self, other: Tensor) -> Tensor: ...
    def __invert__(self) -> Tensor: ...

class Parameter(Tensor):
    def __init__(self, data: TensorData, *, name: str | None = None) -> None: ...
    @property
    def name(self) -> str | None: ...

class Buffer(Tensor):
    def __init__(self, data: TensorData, *, name: str | None = None) -> None: ...
    @property
    def name(self) -> str | None: ...

class SGD:
    def __init__(
        self,
        parameters: Iterable[Parameter],
        lr: float,
        momentum: float = 0.0,
        dampening: float = 0.0,
        weight_decay: float = 0.0,
        nesterov: bool = False,
    ) -> None: ...
    @property
    def lr(self) -> float: ...
    @lr.setter
    def lr(self, value: float) -> None: ...
    @property
    def learning_rate(self) -> float: ...
    @learning_rate.setter
    def learning_rate(self, value: float) -> None: ...
    @property
    def parameter_count(self) -> int: ...
    @property
    def state_size(self) -> int: ...
    def zero_grad(self) -> None: ...
    def step(self) -> None: ...

class Adam:
    def __init__(
        self,
        parameters: Iterable[Parameter],
        lr: float = 0.001,
        betas: tuple[float, float] = (0.9, 0.999),
        eps: float = 1e-8,
        weight_decay: float = 0.0,
        amsgrad: bool = False,
    ) -> None: ...
    @property
    def lr(self) -> float: ...
    @lr.setter
    def lr(self, value: float) -> None: ...
    @property
    def learning_rate(self) -> float: ...
    @learning_rate.setter
    def learning_rate(self, value: float) -> None: ...
    @property
    def betas(self) -> tuple[float, float]: ...
    @property
    def eps(self) -> float: ...
    @property
    def weight_decay(self) -> float: ...
    @property
    def amsgrad(self) -> bool: ...
    @property
    def parameter_count(self) -> int: ...
    @property
    def state_size(self) -> int: ...
    def zero_grad(self) -> None: ...
    def step(self) -> None: ...

class AdamW:
    def __init__(
        self,
        parameters: Iterable[Parameter],
        lr: float = 0.001,
        betas: tuple[float, float] = (0.9, 0.999),
        eps: float = 1e-8,
        weight_decay: float = 0.01,
        amsgrad: bool = False,
    ) -> None: ...
    @property
    def lr(self) -> float: ...
    @lr.setter
    def lr(self, value: float) -> None: ...
    @property
    def learning_rate(self) -> float: ...
    @learning_rate.setter
    def learning_rate(self, value: float) -> None: ...
    @property
    def betas(self) -> tuple[float, float]: ...
    @property
    def eps(self) -> float: ...
    @property
    def weight_decay(self) -> float: ...
    @property
    def amsgrad(self) -> bool: ...
    @property
    def parameter_count(self) -> int: ...
    @property
    def state_size(self) -> int: ...
    def zero_grad(self) -> None: ...
    def step(self) -> None: ...

class Session:
    def __init__(self, path: str | PathLike[str], *, simplify: bool = True) -> None: ...
    @property
    def inputs(self) -> list[str]: ...
    @property
    def outputs(self) -> list[str]: ...
