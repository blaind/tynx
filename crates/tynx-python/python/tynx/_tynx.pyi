class _CaptureSession:
    def __init__(self, *, fullgraph: bool = False) -> None: ...
    def input(self, tensor: Tensor) -> Tensor: ...
    def finish(self, outputs: tuple[Tensor, ...]) -> _CapturedGraph | None: ...
    def release(self, output: Tensor) -> Tensor: ...
    def abort(self) -> None: ...

class _CapturedGraph:
    @property
    def node_count(self) -> int: ...
    @property
    def structure_valid(self) -> bool: ...
    def matches(self, *inputs: Tensor) -> bool: ...
    def __call__(self, *inputs: Tensor) -> tuple[Tensor, ...]: ...

class Device:
    def __init__(self, kind: Literal["default", "cpu", "flex"] = "default") -> None: ...
    def __str__(self) -> str: ...
    def __eq__(self, other: object) -> bool: ...

class Tensor:
    def __init__(
        self,
        data: TensorData | Tensor | range,
        *,
        dtype: TensorDType | None = None,
        device: Device | None = None,
        requires_grad: bool = False,
    ) -> None: ...
    @property
    def shape(self) -> tuple[int, ...]: ...
    @property
    def ndim(self) -> int: ...
    @property
    def numel(self) -> int: ...
    @property
    def dtype(self) -> str: ...
    @property
    def device(self) -> Device: ...
    @property
    def requires_grad(self) -> bool: ...
    @property
    def is_leaf(self) -> bool: ...
    @property
    def grad(self) -> Tensor | None: ...
    def tolist(self) -> list[object]: ...
    def numpy(self) -> NumPyArray: ...
    def item(self) -> float | int | bool: ...
    def detach(self) -> Tensor: ...
    def cast(self, dtype: TensorDType) -> Tensor: ...
    def to(self, device: Device | None = None, *, dtype: TensorDType | None = None) -> Tensor: ...
    def copy_(self, source: Tensor) -> None: ...
    def zero_grad(self) -> None: ...
    def backward(self, gradient: Tensor | None = None) -> None: ...
    def sum(self, dim: ReductionDim | None = None, keepdim: bool = False) -> Tensor: ...
    def mean(self, dim: ReductionDim | None = None, keepdim: bool = False) -> Tensor: ...
    def max(self, dim: ReductionDim | None = None, keepdim: bool = False) -> Tensor: ...
    def min(self, dim: ReductionDim | None = None, keepdim: bool = False) -> Tensor: ...
    def argmax(self, dim: int | None = None, keepdim: bool = False) -> Tensor: ...
    def argmin(self, dim: int | None = None, keepdim: bool = False) -> Tensor: ...
    def sort(
        self, dim: int = -1, descending: bool = False, stable: bool = False
    ) -> tuple[Tensor, Tensor]: ...
    def argsort(self, dim: int = -1, descending: bool = False, stable: bool = False) -> Tensor: ...
    def topk(
        self,
        k: int,
        dim: int | None = None,
        largest: bool = True,
        sorted: bool = True,
    ) -> tuple[Tensor, Tensor]: ...
    @overload
    def nonzero(self, *, as_tuple: Literal[False] = False) -> Tensor: ...
    @overload
    def nonzero(self, *, as_tuple: Literal[True]) -> tuple[Tensor, ...]: ...
    def maximum(self, other: Tensor | TensorScalar) -> Tensor: ...
    def minimum(self, other: Tensor | TensorScalar) -> Tensor: ...
    def relu(self) -> Tensor: ...
    def sigmoid(self) -> Tensor: ...
    def tanh(self) -> Tensor: ...
    def exp(self) -> Tensor: ...
    def log(self) -> Tensor: ...
    def sqrt(self) -> Tensor: ...
    def gelu(self) -> Tensor: ...
    def abs(self) -> Tensor: ...
    def softmax(self, dim: int) -> Tensor: ...
    def log_softmax(self, dim: int) -> Tensor: ...
    def clamp(self, min: float | None = None, max: float | None = None) -> Tensor: ...
    def clip(self, min: float | None = None, max: float | None = None) -> Tensor: ...
    @overload
    def reshape(self, shape: Shape) -> Tensor: ...
    @overload
    def reshape(self, *shape: int) -> Tensor: ...
    @overload
    def view(self, shape: Shape) -> Tensor: ...
    @overload
    def view(self, *shape: int) -> Tensor: ...
    def contiguous(self) -> Tensor: ...
    @overload
    def expand(self, shape: Shape) -> Tensor: ...
    @overload
    def expand(self, *shape: int) -> Tensor: ...
    @overload
    def repeat(self, repeats: Shape) -> Tensor: ...
    @overload
    def repeat(self, *repeats: int) -> Tensor: ...
    def flatten(self, start_dim: int = 0, end_dim: int = -1) -> Tensor: ...
    def transpose(self, dim0: int, dim1: int) -> Tensor: ...
    @property
    def T(self) -> Tensor: ...
    @overload
    def permute(self, dims: Shape) -> Tensor: ...
    @overload
    def permute(self, *dims: int) -> Tensor: ...
    def squeeze(self, dim: int | None = None) -> Tensor: ...
    def unsqueeze(self, dim: int) -> Tensor: ...
    def where(self, condition: Tensor, other: Tensor | TensorScalar) -> Tensor: ...
    def gather(self, dim: int, index: Tensor) -> Tensor: ...
    def index_select(self, dim: int, index: Tensor) -> Tensor: ...
    def __add__(self, other: Tensor | Scalar) -> Tensor: ...
    def __radd__(self, other: Scalar) -> Tensor: ...
    def __iadd__(self, other: Tensor | Scalar) -> Tensor: ...
    def __sub__(self, other: Tensor | Scalar) -> Tensor: ...
    def __rsub__(self, other: Scalar) -> Tensor: ...
    def __isub__(self, other: Tensor | Scalar) -> Tensor: ...
    def __mul__(self, other: Tensor | Scalar) -> Tensor: ...
    def __rmul__(self, other: Scalar) -> Tensor: ...
    def __imul__(self, other: Tensor | Scalar) -> Tensor: ...
    def __truediv__(self, other: Tensor | Scalar) -> Tensor: ...
    def __rtruediv__(self, other: Scalar) -> Tensor: ...
    def __itruediv__(self, other: Tensor | Scalar) -> Tensor: ...
    def __matmul__(self, other: Tensor) -> Tensor: ...
    def __imatmul__(self, other: Tensor) -> Tensor: ...
    def __neg__(self) -> Tensor: ...
    def __abs__(self) -> Tensor: ...
    def __pow__(self, exponent: Tensor | float, modulo: None = None) -> Tensor: ...
    def __rpow__(self, base: float) -> Tensor: ...
    def __ipow__(self, exponent: Tensor | float, modulo: None = None) -> Tensor: ...
    def __len__(self) -> int: ...
    def __float__(self) -> float: ...
    def __int__(self) -> int: ...
    def __getitem__(self, index: object) -> Tensor: ...
    def split(
        self, split_size_or_sections: int | Sequence[int], dim: int = 0
    ) -> tuple[Tensor, ...]: ...
    def chunk(self, chunks: int, dim: int = 0) -> tuple[Tensor, ...]: ...
    def __bool__(self) -> bool: ...
    def __eq__(self, other: Tensor | TensorScalar) -> Tensor: ...  # type: ignore[override]
    def __ne__(self, other: Tensor | TensorScalar) -> Tensor: ...  # type: ignore[override]
    def __lt__(self, other: Tensor | TensorScalar) -> Tensor: ...
    def __le__(self, other: Tensor | TensorScalar) -> Tensor: ...
    def __gt__(self, other: Tensor | TensorScalar) -> Tensor: ...
    def __ge__(self, other: Tensor | TensorScalar) -> Tensor: ...
    def __and__(self, other: Tensor) -> Tensor: ...
    def __or__(self, other: Tensor) -> Tensor: ...
    def __xor__(self, other: Tensor) -> Tensor: ...
    def __invert__(self) -> Tensor: ...

class Parameter(Tensor):
    def __init__(self, data: TensorData | Tensor, *, name: str | None = None) -> None: ...
    @property
    def name(self) -> str | None: ...

class Buffer(Tensor):
    def __init__(self, data: TensorData | Tensor, *, name: str | None = None) -> None: ...
    @property
    def name(self) -> str | None: ...

class ImportedModel:
    def __init__(
        self,
        path: str | PathLike[str],
        *,
        simplify: bool = True,
        initializer_names: dict[str, str] | None = None,
        outputs: list[str] | None = None,
    ) -> None: ...
    @property
    def inputs(self) -> list[str]: ...
    @property
    def outputs(self) -> list[str]: ...
    @overload
    def __call__(self, input: Tensor, /) -> Tensor: ...
    @overload
    def __call__(self, *inputs: Tensor, **named_inputs: Tensor) -> Tensor | dict[str, Tensor]: ...
    def parameters(self) -> list[Parameter]: ...
    def named_parameters(self) -> list[tuple[str, Parameter]]: ...
    def buffers(self) -> list[Buffer]: ...
    def named_buffers(self) -> list[tuple[str, Buffer]]: ...
    def state_dict(self) -> dict[str, Tensor]: ...
    def load_state_dict(self, state_dict: dict[str, Tensor], strict: bool = True) -> object: ...
    def trainability_report(self) -> TrainabilityReport: ...
    def require_trainable(self, outputs: list[str] | None = None) -> TrainabilityReport: ...

class TrainabilityReport:
    @property
    def is_trainable(self) -> bool: ...
    @property
    def selected_outputs(self) -> list[str]: ...
    @property
    def trainable_parameters(self) -> list[str]: ...
    @property
    def buffers(self) -> list[str]: ...
    @property
    def constants(self) -> list[str]: ...
    @property
    def unused_parameters(self) -> list[str]: ...
    @property
    def warnings(self) -> list[str]: ...
    @property
    def errors(self) -> list[str]: ...
    @property
    def output_parameters(self) -> dict[str, list[str]]: ...
    @property
    def initializers(self) -> list[dict[str, object]]: ...
    @property
    def backward_issues(self) -> list[dict[str, object]]: ...
    def require_trainable(self) -> None: ...

OptimizerParameter = Parameter | tuple[str, Parameter]

class SGD:
    def __init__(
        self,
        parameters: Iterable[OptimizerParameter],
        lr: float,
        momentum: float = 0.0,
        dampening: float = 0.0,
        weight_decay: float = 0.0,
        nesterov: bool = False,
    ) -> None: ...
    @property
    def lr(self) -> float: ...
    @lr.setter
    def lr(self, value: float) -> None: ...
    @property
    def learning_rate(self) -> float: ...
    @learning_rate.setter
    def learning_rate(self, value: float) -> None: ...
    @property
    def momentum(self) -> float: ...
    @property
    def dampening(self) -> float: ...
    @property
    def weight_decay(self) -> float: ...
    @property
    def nesterov(self) -> bool: ...
    @property
    def parameter_count(self) -> int: ...
    @property
    def state_size(self) -> int: ...
    def zero_grad(self) -> None: ...
    def step(self) -> None: ...
    def state_dict(self) -> dict[str, object]: ...
    def load_state_dict(self, state_dict: dict[str, object]) -> None: ...
    def _set_config(
        self,
        lr: float,
        momentum: float,
        dampening: float,
        weight_decay: float,
        nesterov: bool,
    ) -> None: ...

