from collections.abc import Iterable, Sequence
from os import PathLike
from typing import Any, Literal, overload

__version__: str

TensorScalar = float | int | bool
_TensorData1 = Sequence[TensorScalar]
_TensorData2 = Sequence[_TensorData1]
_TensorData3 = Sequence[_TensorData2]
_TensorData4 = Sequence[_TensorData3]
_TensorData5 = Sequence[_TensorData4]
_TensorData6 = Sequence[_TensorData5]
# Keep NumPy's version-sensitive stubs out of Tynx's Python 3.9 type surface.
NumPyArray = Any
TensorData = (
    TensorScalar
    | _TensorData1
    | _TensorData2
    | _TensorData3
    | _TensorData4
    | _TensorData5
    | _TensorData6
    | NumPyArray
)
TensorDType = Literal["float32", "int64", "bool"]
ReductionDim = int | tuple[int, ...]
Scalar = int | float
Shape = tuple[int, ...] | list[int]

class _NoGrad:
    def __enter__(self) -> None: ...
    def __exit__(self, exception_type: object, exception: object, traceback: object) -> bool: ...

def no_grad() -> _NoGrad: ...
def is_grad_enabled() -> bool: ...
def manual_seed(seed: int) -> None: ...
def _normal_sample(loc: Tensor, scale: Tensor, seed: int | None = None) -> Tensor: ...
def _categorical_sample(logits: Tensor, seed: int | None = None) -> Tensor: ...
def _dropout(input: Tensor, probability: float) -> Tensor: ...
def _conv2d(
    input: Tensor,
